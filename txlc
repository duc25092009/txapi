# 2. FEATURE ENGINEERING SIÊU CẤP
# ══════════════════════════════════════════════════════════════════
def create_advanced_features(df):
    """Xây dựng hơn 100 đặc trưng (features)"""
    # Chuyển đổi kết quả
    df['label'] = (df['resultTruyenThong'].str.upper().isin(['TAI', 'TÀI'])).astype(int)
    
    # Các đặc trưng điểm số
    df['point'] = df['point'].astype(float)
    df['point_diff'] = df['point'].diff()
    df['point_pct_change'] = df['point'].pct_change()
    df['point_rolling_mean_3'] = df['point'].rolling(3).mean()
    df['point_rolling_mean_5'] = df['point'].rolling(5).mean()
    df['point_rolling_mean_10'] = df['point'].rolling(10).mean()
    df['point_rolling_std_5'] = df['point'].rolling(5).std()
    df['point_rolling_std_10'] = df['point'].rolling(10).std()
    
    # RSI
    delta = df['point'].diff()
    gain = delta.clip(lower=0)
    loss = -delta.clip(upper=0)
    avg_gain = gain.rolling(14).mean()
    avg_loss = loss.rolling(14).mean()
    rs = avg_gain / (avg_loss + 1e-9)
    df['rsi_14'] = 100 - (100 / (1 + rs))
    
    # Bollinger Bands
    df['bb_mid'] = df['point'].rolling(20).mean()
    bb_std = df['point'].rolling(20).std()
    df['bb_upper'] = df['bb_mid'] + 2 * bb_std
    df['bb_lower'] = df['bb_mid'] - 2 * bb_std
    df['bb_position'] = (df['point'] - df['bb_lower']) / (df['bb_upper'] - df['bb_lower'] + 1e-9)
    
    # MACD
    exp1 = df['point'].ewm(span=12).mean()
    exp2 = df['point'].ewm(span=26).mean()
    df['macd'] = exp1 - exp2
    df['macd_signal'] = df['macd'].ewm(span=9).mean()
    df['macd_diff'] = df['macd'] - df['macd_signal']
    
    # Stochastic
    low_14 = df['point'].rolling(14).min()
    high_14 = df['point'].rolling(14).max()
    df['stoch'] = 100 * (df['point'] - low_14) / (high_14 - low_14 + 1e-9)
    
    # ATR (Average True Range)
    df['tr'] = np.maximum(df['point'].diff().abs(), 
                          np.maximum(df['point'] - df['point'].shift(2), 
                                     df['point'].shift(2) - df['point']))
    df['atr'] = df['tr'].rolling(14).mean()
    
    # Xu hướng
    def slope(series):
        x = np.arange(len(series))
        y = series.values
        return np.polyfit(x, y, 1)[0] if len(x) > 1 else 0
    df['trend_slope_5'] = df['point'].rolling(5).apply(slope)
    df['trend_slope_10'] = df['point'].rolling(10).apply(slope)
    
    # Các đặc trưng về kết quả (cửa sổ trượt)
    for w in [2, 3, 5, 7, 10, 15, 20]:
        df[f'tai_ratio_{w}'] = df['label'].rolling(w).mean().shift(1)
        df[f'streak_{w}'] = df['label'].rolling(w).apply(lambda x: (x.diff() != 0).cumsum().iloc[-1] if len(x)>1 else 0).shift(1)
    
    # Lagged labels
    for lag in range(1, 11):
        df[f'label_lag_{lag}'] = df['label'].shift(lag)
    
    # Các đặc trưng về tổng điểm đã lags
    for lag in range(1, 6):
        df[f'point_lag_{lag}'] = df['point'].shift(lag)
    
    # Pattern phát hiện cầu
    df['is_bet_2'] = ((df['label'].shift(1) == df['label'].shift(2)) & 
                      (df['label'].shift(2) == df['label'].shift(3))).astype(int)
    df['is_bet_3'] = ((df['label'].shift(1) == df['label'].shift(2)) & 
                      (df['label'].shift(2) == df['label'].shift(3)) &
                      (df['label'].shift(3) == df['label'].shift(4))).astype(int)
    df['is_alternating'] = ((df['label'].shift(1) != df['label'].shift(2)) &
                            (df['label'].shift(2) != df['label'].shift(3)) &
                            (df['label'].shift(3) != df['label'].shift(4))).astype(int)
    df['is_pair'] = ((df['label'].shift(1) == df['label'].shift(2)) &
                     (df['label'].shift(3) == df['label'].shift(4)) &
                     (df['label'].shift(1) != df['label'].shift(3))).astype(int)
    
    # Mã hóa thời gian (giờ, phút – nếu có timestamp)
    if 'timestamp' in df.columns:
        df['hour'] = pd.to_datetime(df['timestamp']).dt.hour
        df['minute'] = pd.to_datetime(df['timestamp']).dt.minute
    
    # Drop NaN
    df = df.dropna().reset_index(drop=True)
    return df

