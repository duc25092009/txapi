# 4. ENSEMBLE VỚI STACKING + TỐI ƯU THAM SỐ
# ══════════════════════════════════════════════════════════════════
class AdvancedPredictor:
    def __init__(self):
        self.scaler = RobustScaler()
        self.xgb_model = None
        self.rf_model = None
        self.lgb_model = None
        self.lstm_model = None
        self.transformer_model = None
        self.stacking_clf = None
        self.feature_cols = None
        self.seq_len = 20
        self.is_trained = False
    
    def _prepare_sequences(self, X, y):
        """Tạo chuỗi cho LSTM/Transformer"""
        X_seq, y_seq = [], []
        for i in range(self.seq_len, len(X)):
            X_seq.append(X[i-self.seq_len:i])
            y_seq.append(y[i])
        return np.array(X_seq), np.array(y_seq)
    
    def train(self, df, verbose=True):
        """Huấn luyện toàn bộ hệ thống"""
        # Chuẩn bị features
        exclude = ['label', 'resultTruyenThong', 'id', 'timestamp', 'dices']
        self.feature_cols = [c for c in df.columns if c not in exclude]
        X = df[self.feature_cols].values.astype(np.float32)
        y = df['label'].values
        
        # Scale features
        X_scaled = self.scaler.fit_transform(X)
        
        # Chia train/test theo thời gian (80% đầu train, 20% cuối test)
        split = int(len(df) * 0.8)
        X_train, X_test = X_scaled[:split], X_scaled[split:]
        y_train, y_test = y[:split], y[split:]
        
        # 1. XGBoost (tối ưu)
        self.xgb_model = XGBClassifier(
            n_estimators=300, max_depth=6, learning_rate=0.02,
            subsample=0.8, colsample_bytree=0.8, reg_alpha=0.1, reg_lambda=1,
            use_label_encoder=False, eval_metric='logloss', random_state=42
        )
        self.xgb_model.fit(X_train, y_train)
        
        # 2. Random Forest (tối ưu)
        self.rf_model = RandomForestClassifier(
            n_estimators=300, max_depth=10, min_samples_split=5,
            min_samples_leaf=2, random_state=42, n_jobs=-1
        )
        self.rf_model.fit(X_train, y_train)
        
        # 3. Gradient Boosting
        self.lgb_model = GradientBoostingClassifier(
            n_estimators=200, max_depth=5, learning_rate=0.05,
            subsample=0.8, random_state=42
        )
        self.lgb_model.fit(X_train, y_train)
        
        # 4. LSTM
        X_seq_train, y_seq_train = self._prepare_sequences(X_scaled, y)
        if len(X_seq_train) > self.seq_len:
            self.lstm_model = build_improved_lstm(self.seq_len, X_scaled.shape[1])
            early_stop = EarlyStopping(patience=10, restore_best_weights=True)
            self.lstm_model.fit(
                X_seq_train, y_seq_train,
                epochs=50, batch_size=32, validation_split=0.1,
                callbacks=[early_stop], verbose=0
            )
        
        # 5. Stacking Ensemble
        base_models = [
            ('xgb', self.xgb_model),
            ('rf', self.rf_model),
            ('gb', self.lgb_model)
        ]
        meta_model = LogisticRegression(C=1.0, max_iter=1000)
        self.stacking_clf = StackingClassifier(
            estimators=base_models, final_estimator=meta_model,
            cv=5, stack_method='predict_proba'
        )
        self.stacking_clf.fit(X_train, y_train)
        
        # Đánh giá
        if verbose:
            y_pred_stack = self.stacking_clf.predict(X_test)
            acc = accuracy_score(y_test, y_pred_stack)
            print(f"\n🎯 ĐỘ CHÍNH XÁC TRÊN TẬP TEST: {acc:.2%}")
            
            # Dự đoán xác suất
            proba_stack = self.stacking_clf.predict_proba(X_test)[:, 1]
            auc = roc_auc_score(y_test, proba_stack) if len(set(y_test)) > 1 else 0.5
            print(f"🎯 AUC-ROC: {auc:.3f}")
        
        self.is_trained = True
        return self
    
    def predict_proba(self, df, recent_n=30):
        """Dự đoán xác suất Tài cho ván tiếp theo"""
        if not self.is_trained:
            raise ValueError("Model chưa được huấn luyện")
        
        # Lấy dữ liệu mới nhất
        last_rows = df.tail(1).copy()
        X_new = last_rows[self.feature_cols].values.astype(np.float32)
        X_new_scaled = self.scaler.transform(X_new)
        
        # Dự đoán từ stacking
        proba_stack = self.stacking_clf.predict_proba(X_new_scaled)[0, 1]
        
        # Lấy 30 ván gần nhất để phân tích cầu
        recent_labels = df['label'].tail(recent_n).values
        points = df['point'].tail(recent_n).values
        
        # Phân tích streak
        streak = 1
        for i in range(1, min(len(recent_labels), 20)):
            if recent_labels[-i] == recent_labels[-i-1]:
                streak += 1
            else:
                break
        
        # Điều chỉnh dựa trên quy tắc chuyên gia
        adjustment = 0.0
        if streak >= 5:
            # Cầu bệt dài → bẻ cầu
            adjustment = -0.25 if recent_labels[-1] == 1 else 0.25
        elif streak >= 3:
            adjustment = -0.1 if recent_labels[-1] == 1 else 0.1
        elif streak == 1:
            # Kiểm tra cầu 1-1
            is_alternating = all(recent_labels[i] != recent_labels[i+1] 
                                for i in range(min(6, len(recent_labels)-1)))
            if is_alternating:
                adjustment = 0.15 if recent_labels[-1] == 0 else -0.15
        
        # Điều chỉnh từ tổng điểm
        if len(points) >= 5:
            avg_point = np.mean(points[-5:])
            if avg_point > 13:
                adjustment -= 0.08  # Điểm cao → về Xỉu
            elif avg_point < 8:
                adjustment += 0.08  # Điểm thấp → về Tài
        
        final_proba = np.clip(proba_stack + adjustment, 0.05, 0.95)
        return final_proba

