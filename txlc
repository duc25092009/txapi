def update_model_periodically():
    """Tự động cập nhật model mỗi 6 giờ"""
    global predictor, last_train_time
    now = time.time()
    if last_train_time is None or (now - last_train_time) > 21600:  # 6 giờ
        print("🔄 Đang cập nhật mô hình với dữ liệu mới nhất...")
        data = fetch_latest_history(500)
        df_raw = pd.DataFrame(data)
        if len(df_raw) > 100:
            df = create_advanced_features(df_raw)
            if len(df) > 200:
                predictor.train(df, verbose=False)
                last_train_time = now
                print("✅ Cập nhật mô hình thành công")
                return True
    return False

@app.route('/predict', methods=['GET', 'POST'])
def predict_api():
    """API dự đoán ván tiếp theo"""
    try:
        # Cập nhật model định kỳ
        update_model_periodically()
        
        # Lấy dữ liệu mới nhất
        data = fetch_latest_history(300)
        df_raw = pd.DataFrame(data)
        if len(df_raw) < 50:
            return jsonify({"error": "Không đủ dữ liệu lịch sử"}), 400
        
        df = create_advanced_features(df_raw)
        
        if not predictor.is_trained:
            predictor.train(df)
        
        proba = predictor.predict_proba(df)
        pred = "TÀI" if proba >= 0.5 else "XỈU"
        confidence = int(abs(proba - 0.5) * 200)
        confidence = min(99, max(50, confidence))
        
        # Phân tích cầu để thêm thông tin
        recent = df['label'].tail(20).values[::-1]
        streak = 1
        for i in range(1, len(recent)):
            if recent[i] == recent[0]:
                streak += 1
            else:
                break
        last_result = "TÀI" if recent[0] == 1 else "XỈU"
        
        return jsonify({
            "success": True,
            "prediction": pred,
            "confidence": confidence,
            "probability_tai": round(float(proba), 4),
            "analysis": {
                "streak": streak,
                "last_result": last_result,
                "total_rounds": len(df)
            },
            "timestamp": datetime.now().isoformat()
        })
    except Exception as e:
        return jsonify({"error": str(e)}), 500

