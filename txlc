def fetch_latest_history(n=500):
    """Lấy dữ liệu mới nhất, kết hợp với dữ liệu đã lưu"""
    records = []
    for url in API_URLS:
        for proxy in PROXIES:
            try:
                fetch_url = proxy + requests.utils.quote(url, safe='') if proxy else url
                r = requests.get(fetch_url, timeout=10)
                data = r.json()
                lst = data.get("list", [])
                if lst:
                    records = lst[:n]
                    print(f"✅ Lấy {len(records)} ván từ API")
                    break
            except:
                continue
        if records:
            break
    
    # Load dữ liệu cũ nếu có
    if os.path.exists(DATA_FILE):
        old_records = pd.read_pickle(DATA_FILE)
        # Gộp và loại trùng
        all_ids = {r.get('id') for r in records}
        for old in old_records:
            if old.get('id') not in all_ids:
                records.append(old)
        records.sort(key=lambda x: x.get('id', 0), reverse=True)
    
    # Lưu lại
    pd.to_pickle(records[:2000], DATA_FILE)
    return records[:500]

